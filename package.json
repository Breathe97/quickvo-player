    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/node": "^22.13.0",
    "typescript": "~5.9.0",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "private": false,
  "author": "Breathe",
  "keywords": [
